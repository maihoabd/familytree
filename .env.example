# Database URL (Kết nối PostgreSQL của Supabase hoặc Vercel Postgres)
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres?schema=public"

# Khóa bí mật cho NextAuth hoặc các cơ chế quản trị sau này (chuỗi ngẫu nhiên 32 ký tự)
NEXTAUTH_SECRET="nguyen_huu_family_tree_secret_key_random_32_chars"

# Token đọc ghi của Vercel Blob Storage phục vụ upload ảnh chân dung thành viên
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token_here"
